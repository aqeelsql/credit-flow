APP_NAME="CreditFlow Auth Service"
ENVIRONMENT=local
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

DATABASE_URL=postgresql://creditflow:creditflow@localhost:5432/creditflow
DATABASE_SCHEMA=auth
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_EXCHANGE=creditflow.events

BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256
JWT_SECRET=dev-change-me
JWT_ISSUER=creditflow-auth
JWT_AUDIENCE=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_OTP_TTL_SECONDS=600
PASSWORD_RESET_OTP_LENGTH=6
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8

DEFAULT_ACCOUNT_ID=acct_individual_pending
DEFAULT_ROLE=Owner
USER_TENANT_SERVICE_URL=http://localhost:8002
USER_TENANT_SERVICE_TIMEOUT_SECONDS=5
INTERNAL_SERVICE_TOKEN=dev-internal-token
SUPERADMIN_EMAILS=
SECURE_COOKIE=false
REFRESH_COOKIE_NAME=cf_refresh_token



