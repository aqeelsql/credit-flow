APP_NAME="CreditFlow API Gateway"
ENVIRONMENT=local
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JWT_ALGORITHM=HS256
JWT_SECRET=dev-change-me
JWT_PUBLIC_KEY=
JWT_AUDIENCE=
JWT_ISSUER=

REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_EXCHANGE=creditflow.events
WEBHOOK_TTL_SECONDS=86400

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ACCOUNT_REQUESTS=600
RATE_LIMIT_IP_REQUESTS=180
RATE_LIMIT_FAIL_OPEN=false

AUTH_SERVICE_URL=http://localhost:8001
USER_TENANT_SERVICE_URL=http://localhost:8002
CONTENT_SERVICE_URL=http://localhost:8003
CALENDAR_SERVICE_URL=http://localhost:8004
LINKEDIN_SERVICE_URL=http://localhost:8005
BILLING_SERVICE_URL=http://localhost:8006
CREDITS_SERVICE_URL=http://localhost:8007
ADMIN_SERVICE_URL=http://localhost:8008
USAGE_SERVICE_URL=http://localhost:8009
AI_GENERATION_SERVICE_URL=http://localhost:8010

DOWNSTREAM_TIMEOUT_SECONDS=20
SSE_START_TIMEOUT_SECONDS=15

STRIPE_WEBHOOK_SECRET=
LINKEDIN_WEBHOOK_SECRET=
OPENROUTER_WEBHOOK_SECRET=
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
